{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",

        "declaration": false,
        "declarationMap": false,
         "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
    },
    "include": ["src", "prisma.config.ts"]
}